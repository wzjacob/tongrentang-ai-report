  ],
  "inputs": [
    {
      "id": "openAiMopaiSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:3000/ai-mopai-huibao"]
    }
  ]
}
