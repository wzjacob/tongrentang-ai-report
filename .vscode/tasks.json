{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "在 Simple Browser 打开算力摸排与前瞻规划汇报",
      "type": "shell",
      "command": "echo",
      "args": ["${input:openAiMopaiSimpleBrowser}"],
      "problemMatcher": [],
